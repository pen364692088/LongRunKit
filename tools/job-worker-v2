#!/usr/bin/env python3
"""
job-worker-v2 - 增强版 Job Worker

支持:
1. 读取任务上下文 (SESSION-STATE.md 或 spec.json)
2. 执行 AI 任务 (subagent 调用)
3. 执行 Shell 命令
4. 定期心跳
5. sessions_send 回传通知

用法:
    job-worker-v2 <job_id>
"""

import argparse
import json
import os
import sys
import time
import subprocess
import threading
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional, Callable

# 默认配置
JOBS_DIR = Path(__file__).parent.parent / "jobs"
HEARTBEAT_INTERVAL = 30  # 秒


class JobWorker:
    def __init__(self, job_id: str):
        self.job_id = job_id
        self.job_dir = JOBS_DIR / job_id
        self.spec = self.load_spec()
        self.status = self.load_status()
        self.heartbeat_thread = None
        self.stop_heartbeat = threading.Event()
        
    def load_spec(self) -> dict:
        spec_path = self.job_dir / "spec.json"
        if not spec_path.exists():
            raise FileNotFoundError(f"Job spec not found: {spec_path}")
        with open(spec_path) as f:
            return json.load(f)
    
    def load_status(self) -> dict:
        status_path = self.job_dir / "status.json"
        if not status_path.exists():
            raise FileNotFoundError(f"Job status not found: {status_path}")
        with open(status_path) as f:
            return json.load(f)
    
    def update_status(self, updates: dict):
        status_path = self.job_dir / "status.json"
        self.status.update(updates)
        self.status["updated_at"] = datetime.now(timezone.utc).isoformat()
        with open(status_path, "w") as f:
            json.dump(self.status, f, indent=2)
        return self.status
    
    def write_log(self, line: str):
        log_path = self.job_dir / "logs.txt"
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with open(log_path, "a") as f:
            f.write(f"[{ts}] {line}\n")
    
    def heartbeat_loop(self):
        """后台心跳线程"""
        while not self.stop_heartbeat.is_set():
            self.update_status({
                "heartbeat_at": datetime.now(timezone.utc).isoformat()
            })
            time.sleep(HEARTBEAT_INTERVAL)
    
    def start_heartbeat(self):
        """启动心跳线程"""
        self.stop_heartbeat.clear()
        self.heartbeat_thread = threading.Thread(target=self.heartbeat_loop, daemon=True)
        self.heartbeat_thread.start()
        self.write_log("Heartbeat started")
    
    def stop_heartbeat_thread(self):
        """停止心跳线程"""
        self.stop_heartbeat.set()
        if self.heartbeat_thread:
            self.heartbeat_thread.join(timeout=5)
    
    def write_result(self, content: str, is_error: bool = False):
        """写入结果文件"""
        result_path = self.job_dir / "result.md"
        with open(result_path, "w") as f:
            if is_error:
                f.write(f"# Error\n\n{content}\n")
            else:
                f.write(content)
        return result_path
    
    def execute_ai_task(self, prompt: str, repo: str) -> tuple[bool, str]:
        """
        执行 AI 任务
        
        这会在实际部署中调用 subagent
        这里返回一个模拟结果
        """
        self.write_log(f"AI task: {prompt[:100]}...")
        
        # 模拟 AI 执行
        result_lines = [
            f"# AI Task Result\n",
            f"\n## Prompt\n```\n{prompt}\n```\n",
            f"\n## Working Directory\n{repo}\n",
            f"\n## Execution\n",
            f"- Started: {datetime.now().isoformat()}\n",
            f"- Model: (subagent)\n",
        ]
        
        # 检查目录
        if os.path.isdir(repo):
            result_lines.append(f"\n## Files in repo\n")
            for f in sorted(os.listdir(repo))[:20]:
                result_lines.append(f"- {f}\n")
        
        result_lines.append(f"\n## Status\n- Completed: {datetime.now().isoformat()}\n")
        
        return True, "".join(result_lines)
    
    def execute_shell_task(self, command: str, cwd: str) -> tuple[bool, str]:
        """
        执行 Shell 命令任务
        """
        self.write_log(f"Shell task: {command}")
        
        try:
            result = subprocess.run(
                command,
                shell=True,
                cwd=cwd,
                capture_output=True,
                text=True,
                timeout=300  # 5 分钟超时
            )
            
            output = f"# Shell Task Result\n\n## Command\n```\n{command}\n```\n\n## Output\n```\n{result.stdout}\n```\n"
            
            if result.returncode != 0:
                output += f"\n## Error\n```\n{result.stderr}\n```\n"
                return False, output
            
            return True, output
            
        except subprocess.TimeoutExpired:
            return False, f"# Timeout\n\nCommand timed out after 5 minutes: {command}\n"
        except Exception as e:
            return False, f"# Error\n\n{str(e)}\n"
    
    def send_callback(self, result_path: Path):
        """
        发送完成回调
        
        方式 1: sessions_send (OpenClaw 环境)
        方式 2: mailbox 文件 (兜底)
        """
        notify_session = self.spec.get("callbacks", {}).get("notify_session", "agent:main")
        
        msg = json.dumps({
            "type": "job_done",
            "job_id": self.job_id,
            "state": self.status["state"],
            "title": self.spec["title"],
            "result_path": str(result_path),
            "attempt": self.status["attempt"],
            "error": self.status.get("error")
        }, indent=2)
        
        # 写入 mailbox
        mailbox_dir = Path.home() / ".openclaw" / "workspace" / "mailbox"
        mailbox_dir.mkdir(parents=True, exist_ok=True)
        
        notify_file = mailbox_dir / f"job_{self.job_id}_done.json"
        with open(notify_file, "w") as f:
            json.dump({
                "target": notify_session,
                "message": msg,
                "ts": datetime.now(timezone.utc).isoformat()
            }, f, indent=2)
        
        self.write_log(f"Callback written to mailbox: {notify_file}")
        
        # 在 OpenClaw 环境中，这里会调用 sessions_send 工具
        # 由于我们在 worker 脚本中，无法直接调用工具
        # 所以通过 mailbox + watchdog 补发
        
        return notify_file
    
    def run(self) -> int:
        """执行任务"""
        # 检查幂等性
        if self.status["state"] == "DONE":
            self.write_log("Job already completed, skipping")
            result_path = self.job_dir / "result.md"
            self.send_callback(result_path)
            return 0
        
        # 更新状态为 RUNNING
        self.update_status({
            "state": "RUNNING",
            "attempt": self.status["attempt"] + 1,
            "worker_session": f"agent:main:worker:{os.getpid()}",
            "heartbeat_at": datetime.now(timezone.utc).isoformat()
        })
        
        # 启动心跳
        self.start_heartbeat()
        
        try:
            # 获取任务输入
            inputs = self.spec.get("inputs", {})
            goal = inputs.get("goal", "")
            repo = inputs.get("repo", os.getcwd())
            task_type = self.spec.get("task_type", "ai_task")
            
            self.write_log(f"Starting task: {goal}")
            self.write_log(f"Task type: {task_type}")
            self.write_log(f"Working directory: {repo}")
            
            # 执行任务
            if task_type == "shell_task":
                command = inputs.get("command", goal)
                success, result = self.execute_shell_task(command, repo)
            else:
                # 默认 AI 任务
                success, result = self.execute_ai_task(goal, repo)
            
            # 写入结果
            result_path = self.write_result(result, is_error=not success)
            
            # 更新最终状态
            final_state = "DONE" if success else "FAILED"
            self.update_status({
                "state": final_state,
                "error": None if success else result[:500]
            })
            
            self.write_log(f"Task completed: {final_state}")
            
            # 发送回调
            self.send_callback(result_path)
            
            return 0 if success else 1
            
        except Exception as e:
            self.write_log(f"Error: {str(e)}")
            self.update_status({
                "state": "FAILED",
                "error": str(e)
            })
            result_path = self.write_result(str(e), is_error=True)
            self.send_callback(result_path)
            return 1
            
        finally:
            self.stop_heartbeat_thread()


def main():
    parser = argparse.ArgumentParser(description="Execute job (enhanced)")
    parser.add_argument("job_id", help="Job ID to execute")
    parser.add_argument("--no-callback", action="store_true", help="Skip callback")
    
    args = parser.parse_args()
    
    worker = JobWorker(args.job_id)
    exit_code = worker.run()
    
    print(f"\n[RESULT] Job {args.job_id}: {worker.status['state']}")
    print(f"[RESULT] {worker.job_dir / 'result.md'}")
    
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
