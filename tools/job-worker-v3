#!/usr/bin/env python3
"""
job-worker-v3 - 增强版 Job Worker (v0.2)

增强:
1. 原子写入 + 文件锁
2. CAS 更新 (rev 版本号)
3. Lease 机制 (续租)
4. 结构化日志 (ndjson)
5. 错误分类 + 智能重试
"""

import argparse
import json
import os
import sys
import time
import subprocess
import threading
import signal
from datetime import datetime, timezone, timedelta
from pathlib import Path
from typing import Optional

# 添加 tools 目录到 path
sys.path.insert(0, str(Path(__file__).parent))

from joblib import (
    JOBS_DIR, atomic_write_json, read_status_with_rev,
    update_status_cas, update_status_safe, acquire_lease, renew_lease,
    release_lease, is_lease_expired, log_worker_event, mark_acked,
    classify_error, should_retry, ErrorClass, generate_job_id,
    calculate_notify_delay, record_notify, write_log_event
)

HEARTBEAT_INTERVAL = 30  # 秒
LEASE_DURATION = 2  # 分钟


class JobWorker:
    def __init__(self, job_id: str):
        self.job_id = job_id
        self.job_dir = JOBS_DIR / job_id
        self.spec = self.load_spec()
        self.status = None
        self.rev = 0
        self.heartbeat_thread = None
        self.stop_heartbeat = threading.Event()
        self.cancelled = False
        self.owner = f"worker:{os.getpid()}"
        
        # 注册信号处理
        signal.signal(signal.SIGTERM, self.handle_cancel)
        signal.signal(signal.SIGINT, self.handle_cancel)
    
    def handle_cancel(self, signum, frame):
        """处理取消信号"""
        self.cancelled = True
        log_worker_event(self.job_dir, "cancel", f"Received signal {signum}", level="WARN")
    
    def load_spec(self) -> dict:
        spec_path = self.job_dir / "spec.json"
        if not spec_path.exists():
            raise FileNotFoundError(f"Job spec not found: {spec_path}")
        with open(spec_path) as f:
            return json.load(f)
    
    def update_status(self, updates: dict) -> dict:
        """更新状态 (CAS)"""
        self.status, self.rev = update_status_cas(self.job_dir, updates, self.rev)
        return self.status
    
    def update_status_safe(self, updates: dict) -> dict:
        """安全更新 (带重试)"""
        self.status = update_status_safe(self.job_dir, updates)
        self.status, self.rev = read_status_with_rev(self.job_dir)
        return self.status
    
    def write_result(self, content: str, is_error: bool = False):
        """写入结果 (原子)"""
        result_path = self.job_dir / "result.md"
        atomic_write_json(result_path.parent / "result.json", {
            "content": content,
            "is_error": is_error,
            "written_at": datetime.now(timezone.utc).isoformat()
        })
        # 同时写 md 方便阅读
        with open(result_path, "w") as f:
            if is_error:
                f.write(f"# Error\n\n{content}\n")
            else:
                f.write(content)
        return result_path
    
    def heartbeat_loop(self):
        """后台心跳线程"""
        while not self.stop_heartbeat.is_set():
            try:
                # 续租 + 更新心跳
                if renew_lease(self.job_dir, self.owner, LEASE_DURATION):
                    self.update_status_safe({
                        "heartbeat_at": datetime.now(timezone.utc).isoformat()
                    })
                else:
                    log_worker_event(self.job_dir, "lease", "Failed to renew lease", level="WARN")
            except Exception as e:
                log_worker_event(self.job_dir, "heartbeat", f"Error: {e}", level="ERROR")
            
            time.sleep(HEARTBEAT_INTERVAL)
    
    def start_heartbeat(self):
        """启动心跳线程"""
        # 先获取 lease
        if not acquire_lease(self.job_dir, self.owner, LEASE_DURATION):
            raise RuntimeError("Failed to acquire lease")
        
        self.stop_heartbeat.clear()
        self.heartbeat_thread = threading.Thread(target=self.heartbeat_loop, daemon=True)
        self.heartbeat_thread.start()
        
        log_worker_event(self.job_dir, "start", f"Heartbeat started, owner={self.owner}")
    
    def stop_heartbeat_thread(self):
        """停止心跳线程"""
        self.stop_heartbeat.set()
        if self.heartbeat_thread:
            self.heartbeat_thread.join(timeout=5)
        
        # 释放 lease
        release_lease(self.job_dir, self.owner)
    
    def execute_ai_task(self, prompt: str, repo: str) -> tuple:
        """
        执行 AI 任务
        
        Returns:
            (success, result_or_error, error_class)
        """
        log_worker_event(self.job_dir, "execute", f"AI task: {prompt[:100]}...")
        
        # 模拟执行
        try:
            result_lines = [
                f"# AI Task Result\n",
                f"\n## Prompt\n```\n{prompt}\n```\n",
                f"\n## Working Directory\n{repo}\n",
                f"\n## Execution\n",
                f"- Started: {datetime.now().isoformat()}\n",
            ]
            
            # 检查取消
            if self.cancelled:
                return False, "Task cancelled by user", ErrorClass.CANCELLED
            
            # 检查目录
            if os.path.isdir(repo):
                result_lines.append(f"\n## Files in repo\n")
                for f in sorted(os.listdir(repo))[:20]:
                    result_lines.append(f"- {f}\n")
                    if self.cancelled:
                        break
            
            result_lines.append(f"\n## Status\n- Completed: {datetime.now().isoformat()}\n")
            
            return True, "".join(result_lines), None
            
        except Exception as e:
            error_class = classify_error(e)
            return False, str(e), error_class
    
    def execute_shell_task(self, command: str, cwd: str) -> tuple:
        """
        执行 Shell 命令任务
        """
        log_worker_event(self.job_dir, "execute", f"Shell: {command}")
        
        try:
            result = subprocess.run(
                command,
                shell=True,
                cwd=cwd,
                capture_output=True,
                text=True,
                timeout=300
            )
            
            output = f"# Shell Task Result\n\n## Command\n```\n{command}\n```\n\n## Output\n```\n{result.stdout}\n```\n"
            
            if result.returncode != 0:
                output += f"\n## Error\n```\n{result.stderr}\n```\n"
                return False, output, ErrorClass.PERMANENT
            
            return True, output, None
            
        except subprocess.TimeoutExpired:
            return False, f"Timeout after 5 minutes", ErrorClass.TIMEOUT
        except Exception as e:
            error_class = classify_error(e)
            return False, str(e), error_class
    
    def send_callback(self, result_path: Path):
        """发送完成回调"""
        notify_session = self.spec.get("callbacks", {}).get("notify_session", "agent:main")
        
        msg = json.dumps({
            "type": "job_done",
            "job_id": self.job_id,
            "state": self.status["state"],
            "title": self.spec["title"],
            "result_path": str(result_path),
            "attempt": self.status["attempt"],
            "error": self.status.get("error"),
            "error_class": self.status.get("error_class")
        }, indent=2)
        
        # 写入 mailbox
        mailbox_dir = Path.home() / ".openclaw" / "workspace" / "mailbox"
        mailbox_dir.mkdir(parents=True, exist_ok=True)
        
        notify_file = mailbox_dir / f"job_{self.job_id}_done.json"
        atomic_write_json(notify_file, {
            "target": notify_session,
            "message": msg,
            "ts": datetime.now(timezone.utc).isoformat()
        })
        
        # 记录通知
        record_notify(self.job_dir)
        
        log_worker_event(self.job_dir, "callback", f"Written to {notify_file}")
        
        return notify_file
    
    def run(self) -> int:
        """执行任务"""
        # 加载当前状态
        self.status, self.rev = read_status_with_rev(self.job_dir)
        
        if not self.status:
            log_worker_event(self.job_dir, "error", "No status found")
            return 1
        
        # 检查幂等性
        if self.status["state"] == "DONE":
            log_worker_event(self.job_dir, "skip", "Job already completed")
            result_path = self.job_dir / "result.md"
            if result_path.exists():
                self.send_callback(result_path)
            return 0
        
        # 更新状态为 RUNNING (使用 safe 更新)
        attempt = self.status.get("attempt", 0) + 1
        self.status = update_status_safe(self.job_dir, {
            "state": "RUNNING",
            "attempt": attempt,
            "worker_session": self.owner,
            "heartbeat_at": datetime.now(timezone.utc).isoformat()
        })
        
        # 重新读取 rev
        self.status, self.rev = read_status_with_rev(self.job_dir)
        
        log_worker_event(self.job_dir, "start", f"Attempt {attempt}/{self.status.get('max_attempts', 3)}")
        
        # 启动心跳 + lease
        try:
            self.start_heartbeat()
        except RuntimeError as e:
            log_worker_event(self.job_dir, "error", f"Failed to acquire lease: {e}")
            return 1
        
        try:
            # 获取任务输入
            inputs = self.spec.get("inputs", {})
            goal = inputs.get("goal", "")
            repo = inputs.get("repo", os.getcwd())
            task_type = self.spec.get("task_type", "ai_task")
            
            # 执行任务
            if task_type == "shell_task":
                command = inputs.get("command", goal)
                success, result, error_class = self.execute_shell_task(command, repo)
            else:
                success, result, error_class = self.execute_ai_task(goal, repo)
            
            # 写入结果
            result_path = self.write_result(result, is_error=not success)
            
            # 更新最终状态
            final_state = "DONE" if success else "FAILED"
            
            self.status = update_status_safe(self.job_dir, {
                "state": final_state,
                "error": None if success else result[:500],
                "error_class": error_class
            })
            
            log_worker_event(self.job_dir, "complete", f"State: {final_state}")
            
            # 写 summary.json
            summary = {
                "job_id": self.job_id,
                "state": final_state,
                "attempt": attempt,
                "duration_seconds": 0,  # TODO: 计算实际时长
                "error_class": error_class,
                "result_path": str(result_path),
                "completed_at": datetime.now(timezone.utc).isoformat()
            }
            atomic_write_json(self.job_dir / "summary.json", summary)
            
            # 发送回调
            self.send_callback(result_path)
            
            return 0 if success else 1
            
        except Exception as e:
            error_class = classify_error(e)
            log_worker_event(self.job_dir, "error", str(e), level="ERROR")
            
            update_status_safe(self.job_dir, {
                "state": "FAILED",
                "error": str(e)[:500],
                "error_class": error_class
            })
            
            result_path = self.write_result(str(e), is_error=True)
            self.send_callback(result_path)
            
            return 1
            
        finally:
            self.stop_heartbeat_thread()


def main():
    parser = argparse.ArgumentParser(description="Execute job (v3)")
    parser.add_argument("job_id", help="Job ID to execute")
    parser.add_argument("--no-callback", action="store_true", help="Skip callback")
    
    args = parser.parse_args()
    
    worker = JobWorker(args.job_id)
    exit_code = worker.run()
    
    print(f"\n[RESULT] Job {args.job_id}: {worker.status['state'] if worker.status else '?'}")
    print(f"[RESULT] {worker.job_dir / 'result.md'}")
    
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
