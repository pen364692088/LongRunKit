#!/usr/bin/env python3
"""
job-worker - 执行 Job 并完成握手

用法:
    job-worker <job_id>

行为:
    1. 读取 spec.json
    2. 更新 status 为 RUNNING
    3. 执行任务（定期心跳）
    4. 写入 result.md
    5. 更新 status 为 DONE/FAILED
    6. 发送 sessions_send 回传通知
"""

import argparse
import json
import os
import sys
import time
import subprocess
from datetime import datetime, timezone
from pathlib import Path

# 默认配置
JOBS_DIR = Path(__file__).parent.parent / "jobs"
HEARTBEAT_INTERVAL = 30  # 秒


def load_spec(job_id: str) -> dict:
    """加载 spec.json"""
    spec_path = JOBS_DIR / job_id / "spec.json"
    if not spec_path.exists():
        raise FileNotFoundError(f"Job spec not found: {spec_path}")
    with open(spec_path) as f:
        return json.load(f)


def load_status(job_id: str) -> dict:
    """加载 status.json"""
    status_path = JOBS_DIR / job_id / "status.json"
    if not status_path.exists():
        raise FileNotFoundError(f"Job status not found: {status_path}")
    with open(status_path) as f:
        return json.load(f)


def update_status(job_id: str, updates: dict):
    """更新 status.json"""
    status_path = JOBS_DIR / job_id / "status.json"
    status = load_status(job_id)
    status.update(updates)
    status["updated_at"] = datetime.now(timezone.utc).isoformat()
    with open(status_path, "w") as f:
        json.dump(status, f, indent=2)
    return status


def heartbeat(job_id: str):
    """更新心跳时间"""
    update_status(job_id, {
        "heartbeat_at": datetime.now(timezone.utc).isoformat()
    })


def write_result(job_id: str, result: str, is_error: bool = False):
    """写入 result.md"""
    result_path = JOBS_DIR / job_id / "result.md"
    with open(result_path, "w") as f:
        if is_error:
            f.write(f"# Error\n\n{result}\n")
        else:
            f.write(result)
    return result_path


def write_log(job_id: str, log_line: str):
    """追加日志"""
    log_path = JOBS_DIR / job_id / "logs.txt"
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(log_path, "a") as f:
        f.write(f"[{ts}] {log_line}\n")


def send_notification(job_id: str, status: dict, result_path: Path):
    """
    发送完成通知到主会话
    
    使用 sessions_send 或写入 mailbox
    """
    spec = load_spec(job_id)
    notify_session = spec.get("callbacks", {}).get("notify_session", "agent:main")
    
    # 构造通知消息
    msg = json.dumps({
        "type": "job_done",
        "job_id": job_id,
        "state": status["state"],
        "title": spec["title"],
        "result_path": str(result_path),
        "attempt": status["attempt"],
        "error": status.get("error")
    })
    
    # 方式1: 尝试 sessions_send (需要 OpenClaw 环境)
    try:
        # 这里用 subprocess 调用，因为 sessions_send 是 OpenClaw 工具
        # 实际在 subagent 中会用 sessions_send 工具
        print(f"[NOTIFY] Would send to {notify_session}: {msg[:100]}...")
        # 在实际 subagent 中，这会是 sessions_send 工具调用
    except Exception as e:
        print(f"[WARN] Failed to notify: {e}")
    
    # 方式2: 写入 mailbox 作为兜底
    mailbox_dir = Path.home() / ".openclaw" / "workspace" / "mailbox"
    mailbox_dir.mkdir(parents=True, exist_ok=True)
    
    notify_file = mailbox_dir / f"job_{job_id}_done.json"
    with open(notify_file, "w") as f:
        json.dump({
            "target": notify_session,
            "message": msg,
            "ts": datetime.now(timezone.utc).isoformat()
        }, f, indent=2)
    
    print(f"[NOTIFY] Written to mailbox: {notify_file}")


def execute_task(spec: dict, job_id: str) -> tuple[bool, str]:
    """
    执行实际任务
    
    这里是一个示例实现，实际任务执行逻辑需要根据 task_type 分发
    
    Returns:
        (success, result_or_error)
    """
    task_type = spec.get("task_type", "long_task")
    inputs = spec.get("inputs", {})
    goal = inputs.get("goal", "No goal specified")
    repo = inputs.get("repo", os.getcwd())
    
    write_log(job_id, f"Starting task: {goal}")
    write_log(job_id, f"Working directory: {repo}")
    
    # 心跳线程（简化版：在主循环中定期调用）
    last_heartbeat = time.time()
    
    try:
        # 示例：执行一个简单的任务
        # 实际实现会根据 task_type 分发到不同的执行器
        
        result_lines = [f"# Job Result\n"]
        result_lines.append(f"\n## Task\n{goal}\n")
        result_lines.append(f"\n## Execution\n")
        result_lines.append(f"- Started: {datetime.now().isoformat()}\n")
        result_lines.append(f"- Directory: {repo}\n")
        
        # 模拟执行（实际会运行命令或调用工具）
        # 这里检查 repo 目录是否存在
        if os.path.isdir(repo):
            result_lines.append(f"\n## Files\n")
            for f in sorted(os.listdir(repo))[:10]:
                result_lines.append(f"- {f}\n")
        else:
            result_lines.append(f"\n**Warning**: Directory not found: {repo}\n")
        
        result_lines.append(f"\n## Status\n")
        result_lines.append(f"- Completed: {datetime.now().isoformat()}\n")
        result_lines.append(f"- Status: SUCCESS\n")
        
        # 更新心跳
        if time.time() - last_heartbeat > HEARTBEAT_INTERVAL:
            heartbeat(job_id)
            last_heartbeat = time.time()
        
        return True, "".join(result_lines)
        
    except Exception as e:
        error_msg = f"Task failed: {str(e)}"
        write_log(job_id, error_msg)
        return False, error_msg


def main():
    parser = argparse.ArgumentParser(description="Execute job")
    parser.add_argument("job_id", help="Job ID to execute")
    parser.add_argument("--no-notify", action="store_true", help="Skip notification")
    
    args = parser.parse_args()
    job_id = args.job_id
    
    # 加载 spec 和 status
    spec = load_spec(job_id)
    status = load_status(job_id)
    
    # 检查幂等性：如果已经是 DONE，不重复执行
    if status["state"] == "DONE":
        print(f"[SKIP] Job already completed: {job_id}")
        result_path = JOBS_DIR / job_id / "result.md"
        if not args.no_notify:
            send_notification(job_id, status, result_path)
        return 0
    
    # 更新状态为 RUNNING
    status = update_status(job_id, {
        "state": "RUNNING",
        "attempt": status["attempt"] + 1,
        "worker_session": f"agent:main:worker:{os.getpid()}",
        "heartbeat_at": datetime.now(timezone.utc).isoformat()
    })
    
    print(f"[START] Job {job_id}: {spec['title']}")
    print(f"[INFO] Attempt {status['attempt']}/{status['max_attempts']}")
    
    # 执行任务
    success, result = execute_task(spec, job_id)
    
    # 写入结果
    result_path = write_result(job_id, result, is_error=not success)
    
    # 更新最终状态
    final_state = "DONE" if success else "FAILED"
    status = update_status(job_id, {
        "state": final_state,
        "error": None if success else result
    })
    
    print(f"[DONE] Job {job_id}: {final_state}")
    print(f"[RESULT] {result_path}")
    
    # 发送通知
    if not args.no_notify:
        send_notification(job_id, status, result_path)
    
    return 0 if success else 1


if __name__ == "__main__":
    sys.exit(main())
