#!/usr/bin/env bash
set -euo pipefail
SCRIPT_VERSION="1.1.1"
SCRIPT_NAME="longrun"
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
TOOLKIT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
TEMPLATES_DIR="${TOOLKIT_ROOT}/templates"
TASK_FILE="TASK.md"; HEARTBEAT_FILE="HEARTBEAT.md"; DECISIONS_FILE="DECISIONS.md"; CONTEXT_HYGIENE_FILE="CONTEXT_HYGIENE.md"
MEMORY_DIR="memory"; LOGS_DIR="logs"; DOCS_DIR="docs"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
print_error(){ echo -e "${RED}Error: $1${NC}" >&2; }
print_success(){ echo -e "${GREEN}$1${NC}"; }
print_info(){ echo -e "${BLUE}$1${NC}"; }
print_warning(){ echo -e "${YELLOW}Warning: $1${NC}"; }
ts(){ date '+%Y-%m-%d %H:%M:%S'; }
day(){ date '+%Y-%m-%d'; }
today_memory(){ echo "${MEMORY_DIR}/$(day).md"; }
ensure_dirs(){ mkdir -p "$MEMORY_DIR" "$LOGS_DIR" "$DOCS_DIR"; }
copy_template_if_missing(){ [[ -f "$2" ]] && print_info "$2 already exists" || { cp "$1" "$2"; print_success "Created $2"; }; }
install_symlink(){
  local target="$HOME/.local/bin/$SCRIPT_NAME"; mkdir -p "$HOME/.local/bin"
  [[ ":$PATH:" == *":$HOME/.local/bin:"* ]] || { print_warning "$HOME/.local/bin not in PATH"; print_info 'Add: export PATH="$HOME/.local/bin:$PATH"'; }
  if [[ -L "$target" || ! -e "$target" ]]; then ln -sfn "$SCRIPT_PATH" "$target"; print_success "Installed global CLI: $target -> $SCRIPT_PATH"; else print_warning "$target exists and is not a symlink; skipped"; fi
}
update_task_metadata(){ [[ -f "$TASK_FILE" ]] || return 0; local f="$1" v="$2"; grep -q "^\*\*${f}:\*\*" "$TASK_FILE" && sed -i "s|^\*\*${f}:\*\*.*|**${f}:** ${v}|" "$TASK_FILE" || true; grep -q "^- \*\*${f}:\*\*" "$TASK_FILE" && sed -i "s|^- \*\*${f}:\*\*.*|- **${f}:** ${v}|" "$TASK_FILE" || true; }
cmd_init(){
  local project_dir="." force=0
  while [[ $# -gt 0 ]]; do case "$1" in --project|-p) project_dir="$2"; shift 2;; --force) force=1; shift;; *) print_error "Unknown init option: $1"; exit 1;; esac; done
  mkdir -p "$project_dir"; cd "$project_dir"; print_info "Initializing in: $(pwd)"; ensure_dirs
  if [[ $force -eq 1 ]]; then cp "$TEMPLATES_DIR/TASK.md" "$TASK_FILE"; cp "$TEMPLATES_DIR/HEARTBEAT.md" "$HEARTBEAT_FILE"; cp "$TEMPLATES_DIR/DECISIONS.md" "$DECISIONS_FILE"; cp "$TEMPLATES_DIR/CONTEXT_HYGIENE.md" "${DOCS_DIR}/${CONTEXT_HYGIENE_FILE}"; print_success "Templates overwritten (--force)"; else copy_template_if_missing "$TEMPLATES_DIR/TASK.md" "$TASK_FILE"; copy_template_if_missing "$TEMPLATES_DIR/HEARTBEAT.md" "$HEARTBEAT_FILE"; copy_template_if_missing "$TEMPLATES_DIR/DECISIONS.md" "$DECISIONS_FILE"; copy_template_if_missing "$TEMPLATES_DIR/CONTEXT_HYGIENE.md" "${DOCS_DIR}/${CONTEXT_HYGIENE_FILE}"; fi
  install_symlink; print_success "Init complete"; echo "Next: set executable next action in TASK.md"
}
cmd_checkpoint(){ local note="${1:-}"; [[ -n "$note" ]] || { print_error "Usage: $SCRIPT_NAME checkpoint \"note\""; exit 1; }; ensure_dirs; local mf; mf="$(today_memory)"; { echo; echo "## [$(ts)]"; echo "$note"; } >> "$mf"; update_task_metadata "Last Update" "$(ts)"; update_task_metadata "last_update" "$(ts)"; print_success "Checkpoint saved: $mf"; }
cmd_run_once(){
  [[ -f "$TASK_FILE" ]] || { print_error "$TASK_FILE not found. Run '$SCRIPT_NAME init' first."; exit 1; }
  ensure_dirs
  local next_action
  next_action="$(grep -E '^\*\*Next Action:\*\*|^\*\*next_action:\*\*' "$TASK_FILE" | sed -E 's/^\*\*(Next Action|next_action):\*\* *//' | head -n1 || true)"
  [[ -n "$next_action" ]] || { print_error "No executable Next Action set in $TASK_FILE"; exit 1; }
  [[ "$next_action" =~ ^\[(One|Single).*$ ]] && { print_error "Placeholder Next Action found in $TASK_FILE"; exit 1; }
  local stamp log_file; stamp="$(date '+%Y%m%d_%H%M%S')"; log_file="${LOGS_DIR}/run-once_${stamp}.log"
  print_info "Running: $next_action"
  set +e
  { echo "# LongRunKit run-once"; echo "timestamp: $(ts)"; echo "pwd: $(pwd)"; echo "command: $next_action"; echo "--- output ---"; bash -lc "$next_action"; rc=$?; echo "--- exit_code: $rc ---"; exit $rc; } >"$log_file" 2>&1
  rc=$?
  set -e
  update_task_metadata "Last Update" "$(ts)"; update_task_metadata "last_update" "$(ts)"
  print_info "Log: $log_file"; [[ $rc -eq 0 ]] && print_success "run-once success" || print_warning "run-once failed (exit $rc)"
  return $rc
}
cmd_status(){ [[ -f "$TASK_FILE" ]] || { print_error "$TASK_FILE not found. Run '$SCRIPT_NAME init' first."; exit 1; }; echo "LongRunKit Status"; echo "================="; grep -E '^\*\*(GOAL|Phase|Next Action|next_action|Last Update|last_update):\*\*' "$TASK_FILE" || true; echo; echo "Recent logs:"; ls -1t "$LOGS_DIR"/*.log 2>/dev/null | head -n 3 || echo "(none)"; echo; local mf; mf="$(today_memory)"; echo "Today's checkpoint file: $mf"; [[ -f "$mf" ]] && tail -n 8 "$mf" || echo "(no checkpoints today)"; }
cmd_help(){ cat <<USAGE
$SCRIPT_NAME v$SCRIPT_VERSION
Usage:
  $SCRIPT_NAME init [--project DIR] [--force]
  $SCRIPT_NAME checkpoint "note"
  $SCRIPT_NAME run-once
  $SCRIPT_NAME status
USAGE
}
main(){ local cmd="${1:-help}"; shift || true; case "$cmd" in init) cmd_init "$@";; checkpoint) cmd_checkpoint "$@";; run-once) cmd_run_once "$@";; status) cmd_status;; help|-h|--help) cmd_help;; version|-v|--version) echo "$SCRIPT_NAME $SCRIPT_VERSION";; *) print_error "Unknown command: $cmd"; cmd_help; exit 1;; esac; }
main "$@"
