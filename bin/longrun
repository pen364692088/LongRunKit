#!/usr/bin/env bash
set -euo pipefail

SCRIPT_VERSION="2.0.0"
SCRIPT_NAME="longrun"
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
TOOLKIT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
TEMPLATES_DIR="${TOOLKIT_ROOT}/templates"
EXTENSIONS_DIR="${TOOLKIT_ROOT}/extensions"
AGENTIC_DIR="${EXTENSIONS_DIR}/agentic"

TASK_FILE="TASK.md"; HEARTBEAT_FILE="HEARTBEAT.md"; DECISIONS_FILE="DECISIONS.md"; CONTEXT_HYGIENE_FILE="CONTEXT_HYGIENE.md"
MEMORY_DIR="memory"; LOGS_DIR="logs"; DOCS_DIR="docs"; REPORTS_DIR="reports"; TESTS_DIR="tests"; AGENTS_DIR="agents"; SCRIPTS_DIR="scripts"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'
print_error(){ echo -e "${RED}Error: $1${NC}" >&2; }
print_success(){ echo -e "${GREEN}$1${NC}"; }
print_info(){ echo -e "${BLUE}$1${NC}"; }
print_warning(){ echo -e "${YELLOW}Warning: $1${NC}"; }
print_header(){ echo -e "${CYAN}$1${NC}"; }

ts(){ date '+%Y-%m-%d %H:%M:%S'; }
day(){ date '+%Y-%m-%d'; }
today_memory(){ echo "${MEMORY_DIR}/$(day).md"; }

ensure_dirs(){ mkdir -p "$MEMORY_DIR" "$LOGS_DIR" "$DOCS_DIR" "$REPORTS_DIR"; }
ensure_agentic_dirs(){ mkdir -p "$TESTS_DIR" "$AGENTS_DIR" "$SCRIPTS_DIR" "$REPORTS_DIR" ".github/workflows" "golden"; }

copy_template_if_missing(){ [[ -f "$2" ]] && print_info "  $2 already exists" || { cp "$1" "$2"; print_success "  Created $2"; }; }
copy_executable(){ cp "$1" "$2"; chmod +x "$2"; print_success "  Created $2"; }

install_symlink(){
  local target="$HOME/.local/bin/$SCRIPT_NAME"; mkdir -p "$HOME/.local/bin"
  [[ ":$PATH:" == *":$HOME/.local/bin:"* ]] || { print_warning "$HOME/.local/bin not in PATH"; print_info 'Add: export PATH="$HOME/.local/bin:$PATH"'; }
  if [[ -L "$target" || ! -e "$target" ]]; then ln -sfn "$SCRIPT_PATH" "$target"; print_success "Installed global CLI: $target"; else print_warning "$target exists and is not a symlink; skipped"; fi
}

update_task_metadata(){ [[ -f "$TASK_FILE" ]] || return 0; local f="$1" v="$2"; grep -q "^\*\*${f}:\*\*" "$TASK_FILE" && sed -i "s|^\*\*${f}:\*\*.*|**${f}:** ${v}|" "$TASK_FILE" || true; grep -q "^- \*\*${f}:\*\*" "$TASK_FILE" && sed -i "s|^- \*\*${f}:\*\*.*|- **${f}:** ${v}|" "$TASK_FILE" || true; }

cmd_init(){
  local project_dir="." force=0 with_agentic=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project|-p) project_dir="$2"; shift 2;;
      --force|-f) force=1; shift;;
      --with-agentic|-a) with_agentic=1; shift;;
      *) print_error "Unknown init option: $1"; exit 1;;
    esac
  done

  mkdir -p "$project_dir"; cd "$project_dir"
  print_header "🧭 LongRunKit v${SCRIPT_VERSION}"
  print_info "Initializing in: $(pwd)"
  echo ""

  # Core directories
  ensure_dirs

  # Core templates
  print_info "Core templates:"
  if [[ $force -eq 1 ]]; then
    cp "$TEMPLATES_DIR/TASK.md" "$TASK_FILE"
    cp "$TEMPLATES_DIR/HEARTBEAT.md" "$HEARTBEAT_FILE"
    cp "$TEMPLATES_DIR/DECISIONS.md" "$DECISIONS_FILE"
    cp "$TEMPLATES_DIR/CONTEXT_HYGIENE.md" "${DOCS_DIR}/${CONTEXT_HYGIENE_FILE}"
    print_success "  Templates overwritten (--force)"
  else
    copy_template_if_missing "$TEMPLATES_DIR/TASK.md" "$TASK_FILE"
    copy_template_if_missing "$TEMPLATES_DIR/HEARTBEAT.md" "$HEARTBEAT_FILE"
    copy_template_if_missing "$TEMPLATES_DIR/DECISIONS.md" "$DECISIONS_FILE"
    copy_template_if_missing "$TEMPLATES_DIR/CONTEXT_HYGIENE.md" "${DOCS_DIR}/${CONTEXT_HYGIENE_FILE}"
  fi

  # Agentic extension
  if [[ $with_agentic -eq 1 ]]; then
    echo ""
    print_info "Agentic Engineering extension:"
    ensure_agentic_dirs

    # Scripts
    for script in "$AGENTIC_DIR/scripts"/*.sh; do
      [[ -f "$script" ]] && copy_executable "$script" "${SCRIPTS_DIR}/$(basename "$script")"
    done

    # Tests
    for test in "$AGENTIC_DIR/tests"/*.sh; do
      [[ -f "$test" ]] && copy_executable "$test" "${TESTS_DIR}/$(basename "$test")"
    done

    # Agent prompts
    for agent in "$AGENTIC_DIR/agents"/*.md; do
      [[ -f "$agent" ]] && copy_template_if_missing "$agent" "${AGENTS_DIR}/$(basename "$agent")"
    done

    # Docs
    for doc in "$AGENTIC_DIR/docs"/*.md; do
      [[ -f "$doc" ]] && copy_template_if_missing "$doc" "${DOCS_DIR}/$(basename "$doc")"
    done

    # CI workflow
    mkdir -p ".github/workflows"
    copy_template_if_missing "$AGENTIC_DIR/.github/workflows/ci.yml" ".github/workflows/ci.yml"

    # Makefile
    [[ -f "$AGENTIC_DIR/Makefile" ]] && copy_template_if_missing "$AGENTIC_DIR/Makefile" "Makefile"

    # Update timestamps
    [[ -f "$DOCS_DIR/STATUS.md" ]] && sed -i "s/YYYY-MM-DD/$(date +%Y-%m-%d)/g" "$DOCS_DIR/STATUS.md"

    print_success "  Agentic extension installed"
  fi

  # .gitignore
  if [ ! -f ".gitignore" ]; then
    cat > ".gitignore" << 'EOF'
# LongRunKit
logs/
memory/
reports/full.log
reports/*.json

# Editor
*.swp
*.swo
*~
EOF
    print_success "  Created .gitignore"
  fi

  install_symlink

  echo ""
  print_success "✅ Init complete"
  echo ""
  if [[ $with_agentic -eq 1 ]]; then
    echo "🚀 Quick start:"
    echo "   make test-smoke    # 10-30s quick validation"
    echo "   make test-fast     # 1-3min pre-commit tests"
    echo "   longrun checkpoint \"note\"  # Save progress"
  else
    echo "Next: set executable next action in TASK.md"
    echo "Tip: run 'longrun init --with-agentic' for multi-agent workflows"
  fi
}

cmd_checkpoint(){
  local note="${1:-}"
  [[ -n "$note" ]] || { print_error "Usage: $SCRIPT_NAME checkpoint \"note\""; exit 1; }
  ensure_dirs
  local mf; mf="$(today_memory)"
  { echo; echo "## [$(ts)]"; echo "$note"; } >> "$mf"
  update_task_metadata "Last Update" "$(ts)"
  update_task_metadata "last_update" "$(ts)"
  print_success "Checkpoint saved: $mf"
}

cmd_run_once(){
  [[ -f "$TASK_FILE" ]] || { print_error "$TASK_FILE not found. Run '$SCRIPT_NAME init' first."; exit 1; }
  ensure_dirs
  local next_action
  next_action="$(grep -E '^\*\*Next Action:\*\*|^\*\*next_action:\*\*' "$TASK_FILE" | sed -E 's/^\*\*(Next Action|next_action):\*\* *//' | head -n1 || true)"
  [[ -n "$next_action" ]] || { print_error "No executable Next Action set in $TASK_FILE"; exit 1; }
  [[ "$next_action" =~ ^\[(One|Single).*$ ]] && { print_error "Placeholder Next Action found in $TASK_FILE"; exit 1; }

  local stamp log_file; stamp="$(date '+%Y%m%d_%H%M%S')"; log_file="${LOGS_DIR}/run-once_${stamp}.log"
  print_info "Running: $next_action"

  set +e
  { echo "# LongRunKit run-once"; echo "timestamp: $(ts)"; echo "pwd: $(pwd)"; echo "command: $next_action"; echo "--- output ---"; bash -lc "$next_action"; rc=$?; echo "--- exit_code: $rc ---"; exit $rc; } >"$log_file" 2>&1
  rc=$?
  set -e

  update_task_metadata "Last Update" "$(ts)"; update_task_metadata "last_update" "$(ts)"
  print_info "Log: $log_file"
  [[ $rc -eq 0 ]] && print_success "run-once success" || print_warning "run-once failed (exit $rc)"
  return $rc
}

cmd_status(){
  [[ -f "$TASK_FILE" ]] || { print_error "$TASK_FILE not found. Run '$SCRIPT_NAME init' first."; exit 1; }
  echo "LongRunKit Status"
  echo "================="
  grep -E '^\*\*(GOAL|Phase|Next Action|next_action|Last Update|last_update):\*\*' "$TASK_FILE" || true
  echo
  echo "Recent logs:"
  ls -1t "$LOGS_DIR"/*.log 2>/dev/null | head -n 3 || echo "(none)"
  echo
  local mf; mf="$(today_memory)"
  echo "Today's checkpoint: $mf"
  [[ -f "$mf" ]] && tail -n 8 "$mf" || echo "(no checkpoints today)"
}

# Agentic commands
cmd_test_smoke(){
  [[ -f "$TESTS_DIR/test_smoke.sh" ]] || { print_error "Agentic extension not installed. Run 'longrun init --with-agentic' first."; exit 1; }
  bash "$TESTS_DIR/test_smoke.sh"
}

cmd_test_fast(){
  [[ -f "$TESTS_DIR/test_fast.sh" ]] || { print_error "Agentic extension not installed. Run 'longrun init --with-agentic' first."; exit 1; }
  local sample="${SAMPLE:-100}"
  SAMPLE="$sample" bash "$TESTS_DIR/test_fast.sh"
}

cmd_test_full(){
  [[ -f "$TESTS_DIR/test_full.sh" ]] || { print_error "Agentic extension not installed. Run 'longrun init --with-agentic' first."; exit 1; }
  bash "$TESTS_DIR/test_full.sh"
}

cmd_report(){
  [[ -f "$SCRIPTS_DIR/agent_run.sh" ]] || { print_error "Agentic extension not installed. Run 'longrun init --with-agentic' first."; exit 1; }
  local cmd="${1:-echo 'no command specified'}"
  shift || true
  bash "$SCRIPTS_DIR/agent_run.sh" "$cmd" "$@"
}

cmd_help(){
  cat <<USAGE
$SCRIPT_NAME v$SCRIPT_VERSION - Long-running task management with Agentic Engineering

Usage:
  $SCRIPT_NAME init [--project DIR] [--force] [--with-agentic]
  $SCRIPT_NAME checkpoint "note"
  $SCRIPT_NAME run-once
  $SCRIPT_NAME status

Agentic commands (requires --with-agentic):
  $SCRIPT_NAME test-smoke          Run smoke tests (10-30s)
  $SCRIPT_NAME test-fast [SAMPLE]  Run fast tests with optional sampling
  $SCRIPT_NAME test-full           Run full test suite
  $SCRIPT_NAME report "command"    Run command and generate reports

Options:
  --project, -p    Target directory (default: current)
  --force, -f      Overwrite existing templates
  --with-agentic, -a  Install Agentic Engineering extension

Examples:
  $SCRIPT_NAME init --project ~/myproject --with-agentic
  $SCRIPT_NAME checkpoint "completed phase 1"
  $SCRIPT_NAME test-smoke
  SAMPLE=10 $SCRIPT_NAME test-fast
  $SCRIPT_NAME report "pytest tests/"
USAGE
}

main(){
  local cmd="${1:-help}"
  shift || true
  
  # Health check for tool_doctor
  if [[ "$cmd" == "--health" ]]; then
    checks='{"templates_exists":'"$([ -d "$TEMPLATES_DIR" ] && echo true || echo false)"',"extensions_exists":'"$([ -d "$EXTENSIONS_DIR" ] && echo true || echo false)"'}'
    all_healthy=$([ -d "$TEMPLATES_DIR" ] && [ -d "$EXTENSIONS_DIR" ] && echo true || echo false)
    echo "{\"status\":\"$($all_healthy && echo healthy || echo unhealthy)\",\"version\":\"$SCRIPT_VERSION\",\"checks\":$checks}"
    exit $($all_healthy && echo 0 || echo 1)
  fi
  
  # Sample call for tool_doctor
  if [[ "$cmd" == "--sample" ]]; then
    echo "{\"status\":\"ok\",\"sample_result\":{\"version\":\"$SCRIPT_VERSION\",\"templates\":\"$TEMPLATES_DIR\"}}"
    exit 0
  fi
  
  case "$cmd" in
    init) cmd_init "$@";;
    checkpoint) cmd_checkpoint "$@";;
    run-once) cmd_run_once "$@";;
    status) cmd_status;;
    test-smoke|smoke) cmd_test_smoke;;
    test-fast|fast) cmd_test_fast "$@";;
    test-full|full) cmd_test_full;;
    report) cmd_report "$@";;
    help|-h|--help) cmd_help;;
    version|-v|--version) echo "$SCRIPT_NAME $SCRIPT_VERSION";;
    *) print_error "Unknown command: $cmd"; cmd_help; exit 1;;
  esac
}

main "$@"
